@model List<CarJunk.Models.AutoReacondicionado>
@using CarJunk.Models.Enums
@{
    Layout = "_LayoutAdmin";
    ViewData["Breadcrumbs"] = new List<(string, string?, string?)>
    {
        ("Autos Reacondicionados", "Reacondicionados", "Index"),
        ("Agregar Auto", null, null)
    };
}

<div class="admin-page-header admin-page-header-row">
    <div>
        <h1>Autos Reacondicionados</h1>
        <p>Gestiona el inventario de autos reacondicionados</p>
    </div>
    <a asp-controller="Reacondicionados" asp-action="Crear" class="btn-admin-primary">
        <i class="fas fa-plus"></i> Agregar Auto
    </a>
</div>

<div class="admin-card">
    @if (!Model.Any())
    {
        <p class="admin-empty-text">No hay autos registrados</p>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Auto</th>
                    <th>Año</th>
                    <th>Precio</th>
                    <th>Estado</th>
                    <th>Registrado</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var auto in Model)
                {
                    <tr>
                        <td>
                            <div class="table-auto-name">@auto.Marca @auto.Modelo</div>
                            <div class="table-auto-sub">@auto.Color · @auto.Motor</div>
                        </td>
                        <td>@auto.Year</td>
                        <td>$@auto.Precio.ToString("N0")</td>
                        <td>
                            @{
                                string badgeClass = auto.Estado switch
                                {
                                    EstadoAuto.Registro => "badge-gray",
                                    EstadoAuto.Preventa => "badge-blue",
                                    EstadoAuto.Listo => "badge-green",
                                    EstadoAuto.Vendido => "badge-dark",
                                    _ => "badge-gray"
                                };
                            }
                            <span class="badge @badgeClass">@auto.Estado</span>
                        </td>
                        <td class="table-fecha">@auto.FechaRegistro.ToString("dd MMM yyyy")</td>
                        <td>
                            <div class="table-actions">
                                <a asp-controller="Reacondicionados" asp-action="Editar" asp-route-id="@auto.Id"
                                   class="table-action-btn" title="Editar">
                                    <i class="fas fa-pen"></i>
                                </a>
                                <button class="table-action-btn table-action-danger" title="Eliminar"
                                        onclick="confirmarEliminar(@auto.Id)">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@section Scripts {
    <script>
        function confirmarEliminar(id) {
            if (confirm('¿Eliminar este auto? Esta acción no se puede deshacer.')) {
                window.location.href = '/Admin/Reacondicionados/Eliminar/' + id;
            }
        }
    </script>
}