@model CarJunk.ViewModels.AutoDetalleViewModel
@{
    ViewData["Title"] = $"{Model.Auto.Marca} {Model.Auto.Modelo}";
    ViewData["Active"] = "autos";
}

<!-- BREADCRUMB -->
<div class="breadcrumb-bar">
    <a asp-controller="Home" asp-action="Index">Inicio</a>
    <i class="fas fa-chevron-right"></i>
    <a asp-controller="Autos" asp-action="Index">Autos Reacondicionados</a>
    <i class="fas fa-chevron-right"></i>
    <span>@Model.Auto.Marca @Model.Auto.Modelo</span>
</div>

<!-- DETALLE -->
<div class="detalle-wrapper">

    <!-- IMAGEN -->
    <div class="detalle-img-col">
        <div class="detalle-img-box">
            @if (!string.IsNullOrEmpty(Model.Auto.FotoUrl))
            {
                <img src="@Model.Auto.FotoUrl" alt="@Model.Auto.Marca @Model.Auto.Modelo" />
            }
            else
            {
                <div class="detalle-img-placeholder">
                    <i class="fas fa-car-side"></i>
                </div>
            }
            <span class="status-badge status-ready" style="position:absolute;top:16px;left:16px;">
                Listo para Venta
            </span>
        </div>

        <!-- SPECS RÁPIDOS -->
        <div class="detalle-specs-grid">
            <div class="detalle-spec-box">
                <div class="detalle-spec-icon"><i class="fas fa-cog"></i></div>
                <div class="detalle-spec-label">Motor</div>
                <div class="detalle-spec-val">@Model.Auto.Motor</div>
            </div>
            <div class="detalle-spec-box">
                <div class="detalle-spec-icon"><i class="fas fa-chart-line"></i></div>
                <div class="detalle-spec-label">Kilometraje</div>
                <div class="detalle-spec-val">@Model.Auto.Kilometraje.ToString("N0") km</div>
            </div>
            <div class="detalle-spec-box">
                <div class="detalle-spec-icon"><i class="fas fa-calendar"></i></div>
                <div class="detalle-spec-label">Año</div>
                <div class="detalle-spec-val">@Model.Auto.Year</div>
            </div>
            <div class="detalle-spec-box">
                <div class="detalle-spec-icon"><i class="fas fa-palette"></i></div>
                <div class="detalle-spec-label">Color</div>
                <div class="detalle-spec-val">@Model.Auto.Color</div>
            </div>
        </div>
    </div>

    <!-- INFO -->
    <div class="detalle-info-col">

        <div class="detalle-badge-row">
            <span class="detalle-categoria">Reacondicionado</span>
            <span class="detalle-fecha">
                Registrado el @Model.Auto.FechaRegistro.ToString("dd MMM yyyy")
            </span>
        </div>

        <h1 class="detalle-titulo">@Model.Auto.Marca @Model.Auto.Modelo</h1>
        <p class="detalle-year">@Model.Auto.Year</p>

        <div class="detalle-precio">$@Model.Auto.Precio.ToString("N0")</div>

        @if (!string.IsNullOrEmpty(Model.Auto.Descripcion))
        {
            <div class="detalle-desc-block">
                <div class="detalle-desc-title">
                    <i class="fas fa-info-circle"></i> Descripción
                </div>
                <p class="detalle-desc">@Model.Auto.Descripcion</p>
            </div>
        }

        <!-- GARANTÍA -->
        <div class="detalle-garantia">
            <div class="garantia-item">
                <i class="fas fa-shield-alt"></i>
                <span>Garantía de calidad incluida</span>
            </div>
            <div class="garantia-item">
                <i class="fas fa-check-circle"></i>
                <span>Revisión mecánica certificada</span>
            </div>
            <div class="garantia-item">
                <i class="fas fa-file-alt"></i>
                <span>Documentación en regla</span>
            </div>
        </div>

        <!-- CTA -->
        <div class="detalle-cta">
            <a href="tel:+525512345678" class="btn-primary" style="flex:1;justify-content:center;">
                <i class="fas fa-phone"></i> Llamar ahora
            </a>
            <a href="https://wa.me/525512345678?text=Hola, me interesa el @(Model.Auto.Marca) @(Model.Auto.Modelo) @(Model.Auto.Year)"
               target="_blank" class="btn-whatsapp">
                <i class="fab fa-whatsapp"></i> WhatsApp
            </a>
        </div>

        <a asp-controller="Autos" asp-action="Index" class="detalle-volver">
            <i class="fas fa-arrow-left"></i> Volver al catálogo
        </a>
    </div>

</div>