<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — CarJunk Admin</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="admin-body">

    <nav class="admin-topbar">
        <div class="admin-brand">
            <i class="fas fa-car-side"></i>
            <div class="admin-brand-text">
                <strong>CarJunk Admin</strong>
                <span>Panel de Administración</span>
            </div>
        </div>
        <div class="admin-topbar-actions">
            <a asp-controller="Home" asp-action="Index" class="admin-link-vista" target="_blank">
                <i class="fas fa-eye"></i> Vista Cliente
            </a>
            <a asp-controller="Auth" asp-action="Logout" class="admin-link-salir">
                <i class="fas fa-sign-out-alt"></i> Salir
            </a>
        </div>
    </nav>

    <div class="admin-layout">
        <aside class="admin-sidebar">
            <nav class="admin-nav">
                <a asp-controller="Admin" asp-action="Index"
                   class="admin-nav-item @(ViewData["Active"]?.ToString() == "dashboard" ? "active" : "")">
                    <i class="fas fa-th-large"></i> Dashboard
                </a>
                <a asp-controller="Reacondicionados" asp-action="Index"
                   class="admin-nav-item @(ViewData["Active"]?.ToString() == "reacondicionados" ? "active" : "")">
                    <i class="fas fa-car-side"></i> Autos Reacondicionados
                </a>
                <a asp-controller="PiezasAdmin" asp-action="Index"
                   class="admin-nav-item @(ViewData["Active"]?.ToString() == "autospiezas" ? "active" : "")">
                    <i class="fas fa-cube"></i> Autos para Piezas
                </a>
                <a asp-controller="PiezasAdmin" asp-action="Inventario"
                   class="admin-nav-item @(ViewData["Active"]?.ToString() == "inventario" ? "active" : "")">
                    <i class="fas fa-bars"></i> Inventario de Piezas
                </a>
                <a asp-controller="Desperdicio" asp-action="Index"
                   class="admin-nav-item @(ViewData["Active"]?.ToString() == "desperdicio" ? "active" : "")">
                    <i class="fas fa-trash"></i> Desperdicio
                </a>
            </nav>

            <div class="admin-nav-footer">
                <a asp-controller="Admin" asp-action="Configuracion" class="admin-nav-item">
                    <i class="fas fa-cog"></i> Configuración
                </a>
            </div>
        </aside>

        <main class="admin-content">
            @RenderBody()
        </main>
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>